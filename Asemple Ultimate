-- LOGICA: ESP ULTIMATE (BOX, HEALTH, TRACERS)
-- ==========================================
local espCache = {}

local function clearESP(plr)
    if espCache[plr] then
        espCache[plr].B:Destroy() espCache[plr].T:Destroy()
        if espCache[plr].HBg then espCache[plr].HBg:Destroy() end
        if espCache[plr].Line then espCache[plr].Line:Destroy() end
        espCache[plr] = nil
    end
end

Players.PlayerRemoving:Connect(clearESP)

RunService.RenderStepped:Connect(function()
    if not settings.esp and not settings.espTracers then 
        for plr, _ in pairs(espCache) do clearESP(plr) end 
        return 
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local char = plr.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local head = char and char:FindFirstChild("Head")
            local rootPart = char and char:FindFirstChild("HumanoidRootPart")
            
            if char and hum and hum.Health > 0 and head and rootPart then
                local tPos, tOn = camera:WorldToViewportPoint(head.Position + Vector3.new(0,0.5,0))
                local bPos, bOn = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0,3,0))
                
                if tOn or bOn then
                    if not espCache[plr] then
                        local b = Instance.new("Frame", ScreenGui) b.BackgroundTransparency = 1
                        Instance.new("UIStroke", b).Thickness = 1.2
                        local t = Instance.new("TextLabel", ScreenGui) t.BackgroundTransparency = 1 t.Font = Enum.Font.GothamBold t.TextSize = 10 t.TextColor3 = Color3.new(1,1,1)
                        local hBg = Instance.new("Frame", ScreenGui) hBg.BorderSizePixel = 0 hBg.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                        local hFill = Instance.new("Frame", hBg) hFill.BorderSizePixel = 0
                        local line = Instance.new("Frame", ScreenGui) line.BorderSizePixel = 0 line.AnchorPoint = Vector2.new(0.5, 0.5) line.ZIndex = 0
                        
                        espCache[plr] = {B = b, T = t, HBg = hBg, HFill = hFill, Line = line}
                    end
                    
                    local color = COLORS.Gold
                    if settings.teamCheck then color = (plr.Team == player.Team) and COLORS.Ally or COLORS.Enemy end
                    
                    local h = math.abs(bPos.Y - tPos.Y)
                    local w = h / 1.8
                    
                    -- Render ESP Box
                    if settings.esp then
                        espCache[plr].B.Size = UDim2.new(0, w, 0, h)
                        espCache[plr].B.Position = UDim2.new(0, tPos.X - w/2, 0, tPos.Y)
                        espCache[plr].B.UIStroke.Color = color
                        espCache[plr].B.Visible = true
                        
                        espCache[plr].T.Text = plr.DisplayName .. " ["..math.floor((camera.CFrame.p - rootPart.Position).Magnitude).."m]"
                        espCache[plr].T.Position = UDim2.new(0, tPos.X - w/2, 0, tPos.Y - 15)
                        espCache[plr].T.Size = UDim2.new(0, w, 0, 15)
                        espCache[plr].T.TextColor3 = color
                        espCache[plr].T.Visible = true
                        
                        if settings.espHealth then
                            local hpPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                            espCache[plr].HBg.Size = UDim2.new(0, 3, 0, h) espCache[plr].HBg.Position = UDim2.new(0, (tPos.X - w/2) - 6, 0, tPos.Y)
                            espCache[plr].HFill.Size = UDim2.new(1, 0, hpPct, 0) espCache[plr].HFill.Position = UDim2.new(0, 0, 1 - hpPct, 0)
                            espCache[plr].HFill.BackgroundColor3 = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), hpPct)
                            espCache[plr].HBg.Visible = true
                        else
                            espCache[plr].HBg.Visible = false
                        end
                    else
                        espCache[plr].B.Visible = false
                        espCache[plr].T.Visible = false
                        espCache[plr].HBg.Visible = false
                    end

                    -- Render Tracers (Linhas)
                    if settings.espTracers then
                        local screenBottom = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        local targetFoot = Vector2.new(bPos.X, bPos.Y)
                        local distance = (screenBottom - targetFoot).Magnitude
                        local angle = math.deg(math.atan2(targetFoot.Y - screenBottom.Y, targetFoot.X - screenBottom.X))
                        
                        espCache[plr].Line.Size = UDim2.new(0, distance, 0, 1.5)
                        espCache[plr].Line.Position = UDim2.new(0, (screenBottom.X + targetFoot.X) / 2, 0, (screenBottom.Y + targetFoot.Y) / 2)
                        espCache[plr].Line.Rotation = angle
                        espCache[plr].Line.BackgroundColor3 = color
                        espCache[plr].Line.Visible = true
                    else
                        espCache[plr].Line.Visible = false
                    end
                else 
                    if espCache[plr] then clearESP(plr) end 
                end
            else
                if espCache[plr] then clearESP(plr) end
            end
        end
    end
end)

