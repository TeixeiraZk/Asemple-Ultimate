local uiElements = {}

local function createCheckbox(parent, text, key, onClickCallback)
    local F = Instance.new("Frame", parent) F.Size = UDim2.new(1, 0, 0, 20) F.BackgroundTransparency = 1
    local L = Instance.new("TextLabel", F) L.Text = text L.Size = UDim2.new(1,-30,1,0) L.TextColor3 = COLORS.SubText L.Font = Enum.Font.Gotham L.TextSize = 11 L.TextXAlignment = Enum.TextXAlignment.Left L.BackgroundTransparency = 1
    local B = Instance.new("TextButton", F) B.Size = UDim2.new(0,18,0,18) B.Position = UDim2.new(1,-18,0.5,-9) B.BackgroundColor3 = COLORS.Bg B.Text = "" Instance.new("UICorner", B).CornerRadius = UDim.new(0,4)
    local S = Instance.new("UIStroke", B) S.Color = COLORS.Border
    local T = Instance.new("TextLabel", B) T.Text = "✓" T.Size = UDim2.new(1,0,1,0) T.TextColor3 = COLORS.Bg T.Font = Enum.Font.GothamBold T.Visible = settings[key] T.BackgroundTransparency = 1
    
    if settings[key] then B.BackgroundColor3 = COLORS.Gold; S.Color = COLORS.Gold end
    
    local function UpdateUI()
        T.Visible = settings[key]
        B.BackgroundColor3 = settings[key] and COLORS.Gold or COLORS.Bg
        S.Color = settings[key] and COLORS.Gold or COLORS.Border
        if key == "showFov" then FOVCircle.Visible = settings[key] end
    end
    
    uiElements[key] = {Type = "Checkbox", Update = UpdateUI}

    B.MouseButton1Click:Connect(function()
        settings[key] = not settings[key]
        UpdateUI()
        if onClickCallback then onClickCallback(settings[key]) end
    end)
end

local function createSlider(parent, text, min, max, key)
    local F = Instance.new("Frame", parent) F.Size = UDim2.new(1, 0, 0, 35) F.BackgroundTransparency = 1
    local L = Instance.new("TextLabel", F) L.Size = UDim2.new(1, -30, 0, 15) L.Text = text L.TextColor3 = COLORS.SubText L.Font = Enum.Font.Gotham L.TextSize = 10 L.TextXAlignment = Enum.TextXAlignment.Left L.BackgroundTransparency = 1
    local V = Instance.new("TextLabel", F) V.Size = UDim2.new(0, 30, 0, 15) V.Position = UDim2.new(1, -30, 0, 0) V.Text = tostring(settings[key]) V.TextColor3 = COLORS.Gold V.Font = Enum.Font.GothamBold V.TextSize = 10 V.BackgroundTransparency = 1
    local Bar = Instance.new("TextButton", F) Bar.Size = UDim2.new(1, 0, 0, 5) Bar.Position = UDim2.new(0, 0, 1, -5) Bar.BackgroundColor3 = COLORS.Bg Bar.Text = "" Instance.new("UICorner", Bar)
    local Fill = Instance.new("Frame", Bar) Fill.Size = UDim2.new((settings[key]-min)/(max-min), 0, 1, 0) Fill.BackgroundColor3 = COLORS.Gold Fill.BorderSizePixel = 0 Instance.new("UICorner", Fill)

    local function UpdateUI()
        Fill.Size = UDim2.new((settings[key]-min)/(max-min), 0, 1, 0)
        if key == "maxDistance" then V.Text = tostring(settings[key]) .. "m" else V.Text = tostring(settings[key]) end
        if key == "fov" then FOVCircle.Size = UDim2.new(0, settings[key] * 2, 0, settings[key] * 2) end
    end
    
    uiElements[key] = {Type = "Slider", Update = UpdateUI}

    local drag = false
    local function move()
        local p = math.clamp((UserInputService:GetMouseLocation().X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
        settings[key] = math.floor(min + (max - min) * p)
        UpdateUI()
    end
    Bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true move() end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    RunService.RenderStepped:Connect(function() if drag then move() end end)
end

local function createSelector(parent, title)
    local F = Instance.new("Frame", parent) F.Size = UDim2.new(1, 0, 0, 35) F.BackgroundTransparency = 1
    local L = Instance.new("TextLabel", F) L.Size = UDim2.new(1, 0, 0, 12) L.Text = title L.TextColor3 = COLORS.SubText L.Font = Enum.Font.Gotham L.TextSize = 10 L.TextXAlignment = Enum.TextXAlignment.Left L.BackgroundTransparency = 1
    local SelectorBg = Instance.new("Frame", F) SelectorBg.Size = UDim2.new(1, 0, 0, 20) SelectorBg.Position = UDim2.new(0, 0, 1, -20) SelectorBg.BackgroundColor3 = COLORS.Bg Instance.new("UICorner", SelectorBg).CornerRadius = UDim.new(0, 4) Instance.new("UIStroke", SelectorBg).Color = COLORS.Border

    local parts = {"Head", "HumanoidRootPart"}
    local displayNames = {"HEAD", "BODY"}
    
    local LeftBtn = Instance.new("TextButton", SelectorBg) LeftBtn.Size = UDim2.new(0, 20, 1, 0) LeftBtn.BackgroundTransparency = 1 LeftBtn.Text = "<" LeftBtn.TextColor3 = COLORS.Gold LeftBtn.Font = Enum.Font.GothamBold
    local RightBtn = Instance.new("TextButton", SelectorBg) RightBtn.Size = UDim2.new(0, 20, 1, 0) RightBtn.Position = UDim2.new(1, -20, 0, 0) RightBtn.BackgroundTransparency = 1 RightBtn.Text = ">" RightBtn.TextColor3 = COLORS.Gold RightBtn.Font = Enum.Font.GothamBold
    local ValueTxt = Instance.new("TextLabel", SelectorBg) ValueTxt.Size = UDim2.new(1, -40, 1, 0) ValueTxt.Position = UDim2.new(0, 20, 0, 0) ValueTxt.Text = "HEAD" ValueTxt.TextColor3 = COLORS.Text ValueTxt.Font = Enum.Font.GothamBold ValueTxt.TextSize = 10 ValueTxt.BackgroundTransparency = 1

    local function updatePart(step)
        local currentIndex = (settings.aimPart == "Head") and 1 or 2
        currentIndex = currentIndex + step
        if currentIndex > #parts then currentIndex = 1 elseif currentIndex < 1 then currentIndex = #parts end
        settings.aimPart = parts[currentIndex]
        ValueTxt.Text = displayNames[currentIndex]
    end
    
    uiElements["aimPart"] = {Type = "Selector", Update = function() ValueTxt.Text = (settings.aimPart == "Head") and "HEAD" or "BODY" end}

    LeftBtn.MouseButton1Click:Connect(function() updatePart(-1) end)
    RightBtn.MouseButton1Click:Connect(function() updatePart(1) end)
end

