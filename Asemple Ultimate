    Instance.new("UICorner", Right) Instance.new("UIStroke", Right).Color = COLORS.Border
    
    local function addL(parent, title)
        local T = Instance.new("TextLabel", parent)
        T.Text = "  " .. title T.Size = UDim2.new(1, 0, 0, 30) T.TextColor3 = COLORS.Text T.Font = Enum.Font.GothamBold T.TextSize = 12 T.BackgroundTransparency = 1 T.TextXAlignment = Enum.TextXAlignment.Left
