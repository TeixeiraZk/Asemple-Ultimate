        local C = Instance.new("Frame", parent)
        C.Size = UDim2.new(1, -10, 1, -40) C.Position = UDim2.new(0, 5, 0, 35) C.BackgroundTransparency = 1
        local L = Instance.new("UIListLayout", C) L.Padding = UDim.new(0, 8)
        if parent:IsA("ScrollingFrame") then
            L:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() parent.CanvasSize = UDim2.new(0, 0, 0, L.AbsoluteContentSize.Y + 40) end)
        end
        return C
