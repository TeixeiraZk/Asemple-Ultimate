-- LÓGICA DO X-RAY
local xrayCache = {}
local function applyXray(enable)
    if enable then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj:IsDescendantOf(player.Character) and not Players:GetPlayerFromCharacter(obj.Parent) then
                if not xrayCache[obj] then xrayCache[obj] = obj.LocalTransparencyModifier end
                obj.LocalTransparencyModifier = 0.65
            end
        end
    else
        for obj, originalVal in pairs(xrayCache) do
            if obj and obj.Parent then obj.LocalTransparencyModifier = originalVal end
        end
        xrayCache = {}
    end
end
createCheckbox(UtilsR, "X-Ray (Wallhack)", "xray", applyXray)

