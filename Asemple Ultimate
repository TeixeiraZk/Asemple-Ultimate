-- ==========================================
-- LÓGICA CORE: AIMBOT RAGE & SILENT AIM & SPINBOT
-- ==========================================
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    
    if settings.showFov then FOVCircle.Visible = true FOVCircle.Position = UDim2.new(0, mousePos.X, 0, mousePos.Y) else FOVCircle.Visible = false end

    -- Spinbot Visual 
    if settings.spinbot and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local root = player.Character.HumanoidRootPart
        root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(settings.spinSpeed), 0)
    end

    if settings.aimbotRage or settings.silentAim then
        local target = nil
        local closest3DDist = 250
        
        local myChar = player.Character
        local myRoot = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar:FindFirstChild("Head"))
        
        if myRoot then
            for _, p in pairs(Players:GetPlayers()) do
                local isEnemy = true
                if settings.teamCheck and player.Team and p.Team == player.Team then isEnemy = false end
                
                if p ~= player and isEnemy and p.Character then
                    local hum = p.Character:FindFirstChild("Humanoid")
                    local targetPart = p.Character:FindFirstChild(settings.aimPart)

                    if hum and hum.Health > 0 and targetPart then
                        local pos, vis = camera:WorldToViewportPoint(targetPart.Position)
                        if vis then
                            local mDist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                            if mDist < settings.fov then 
                                local realDist = (myRoot.Position - targetPart.Position).Magnitude
                                if realDist <= settings.maxDistance then
                                    if realDist < closest3DDist then 
                                        closest3DDist = realDist
                                        target = targetPart 
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        
        if target then 
            if settings.silentAim then
                if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
                    camera.CFrame = CFrame.lookAt(camera.CFrame.Position, target.Position)
                end
            elseif settings.aimbotRage then
                local smoothFactor = settings.aimSmooth / 10
                camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, target.Position), smoothFactor)
            end
        end
    end
end)

