local function updateTeleportList()
    for _, c in ipairs(TeleTab:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local B = Instance.new("TextButton", TeleTab)
            B.Size = UDim2.new(1, 0, 0, 28) B.BackgroundColor3 = COLORS.Panel
            B.Text = "   " .. p.DisplayName .. " (@" .. p.Name .. ")" B.TextColor3 = COLORS.Text B.Font = Enum.Font.Gotham B.TextSize = 11 B.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", B).CornerRadius = UDim.new(0, 4)
            Instance.new("UIStroke", B).Color = COLORS.Border
            
            B.MouseButton1Click:Connect(function()
                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                end
            end)
        end
    end
end
Players.PlayerAdded:Connect(updateTeleportList)
